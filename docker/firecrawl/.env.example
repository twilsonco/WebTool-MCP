# ===== Required ENVS =====
PORT=3002
HOST=0.0.0.0

# Redis configuration - use service name for docker networking
REDIS_URL=redis://redis:6379
REDIS_RATE_LIMIT_URL=redis://redis:6379

# Playwright microservice URL - use service name for docker networking
PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape

# Database authentication (set to false for self-hosted without Supabase)
USE_DB_AUTHENTICATION=false

# ===== Optional ENVS =====

## === Concurrency & Performance Settings ===
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5

## === AI Features (JSON format on scrape, /extract API) ===
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/api
# MODEL_NAME=deepseek-r1:7b
# MODEL_EMBEDDING_NAME=nomic-embed-text
# OPENAI_BASE_URL=https://example.com/v1

## === Proxy Settings ===
# PROXY_SERVER can be a full URL (e.g. http://0.1.2.3:1234) or just IP:port
# PROXY_USERNAME=
# PROXY_PASSWORD=

## === /search API ===
# SEARXNG_ENDPOINT=http://your.searxng.server
# SEARXNG_ENGINES=
# SEARXNG_CATEGORIES=

## === PostgreSQL Database Configuration ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=nuq-postgres
POSTGRES_PORT=5432

## === RabbitMQ Configuration ===
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

## === Supabase Setup (optional) ===
# SUPABASE_ANON_TOKEN=
# SUPABASE_URL=
# SUPABASE_SERVICE_TOKEN=

## === Bull Queue Manager UI ===
BULL_AUTH_KEY=CHANGEME

## === Testing API Key (optional) ===
TEST_API_KEY=

## === LlamaParse for PDF parsing (optional) ===
LLAMAPARSE_API_KEY=

## === Slack Notifications (optional) ===
SLACK_WEBHOOK_URL=

## === Autumn Secret Key (optional) ===
AUTUMN_SECRET_KEY=

## === Self-hosted Webhook Configuration ===
SELF_HOSTED_WEBHOOK_URL=
SELF_HOSTED_WEBHOOK_HMAC_SECRET=

## === PostHog Analytics (optional) ===
# POSTHOG_API_KEY=
# POSTHOG_HOST=

## === Logging Level ===
# Options: NONE, ERROR, WARN, INFO, DEBUG, TRACE
LOGGING_LEVEL=INFO

## === System Resource Configuration ===
# Maximum CPU usage threshold (0.0-1.0). Worker rejects new jobs when exceeded.
MAX_CPU=0.8
# Maximum RAM usage threshold (0.0-1.0). Worker rejects new jobs when exceeded.
MAX_RAM=0.8

## === Allow Local Webhooks ===
ALLOW_LOCAL_WEBHOOKS=true

## === Block Media Requests ===
BLOCK_MEDIA=

## === Internal Ports (usually don't need to change) ===
INTERNAL_PORT=3002
EXTRACT_WORKER_PORT=3004
WORKER_PORT=3005

## === Harness Startup Timeout ===
HARNESS_STARTUP_TIMEOUT_MS=60000