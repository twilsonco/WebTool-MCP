# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Configure multiple LLM providers with automatic failover support.
# Providers are tried in order (1, 2, 3...). If provider 1 fails, provider 2 is used, etc.
# At least one provider must be configured using LLM_PROVIDER_1_* variables.

## Provider 1 (Primary - highest priority)
LLM_PROVIDER_1_NAME=ollama-local
LLM_PROVIDER_1_BASE_URL=http://localhost:11434/v1
LLM_PROVIDER_1_API_KEY=
LLM_PROVIDER_1_MODEL=llama3.2

## Provider 1 (Primary - highest priority)
LLM_PROVIDER_1_NAME=ollama-local
LLM_PROVIDER_1_BASE_URL=http://localhost:11434/v1
LLM_PROVIDER_1_API_KEY=
LLM_PROVIDER_1_MODEL=llama3.2

## Provider 2 (Failover - cloud backup)
# LLM_PROVIDER_2_NAME=openai-cloud
# LLM_PROVIDER_2_BASE_URL=https://api.openai.com/v1
# LLM_PROVIDER_2_API_KEY=sk-...
# LLM_PROVIDER_2_MODEL=gpt-4o-mini

## Provider 3 (Additional fallback)
# LLM_PROVIDER_3_NAME=anthropic-cloud
# LLM_PROVIDER_3_BASE_URL=https://api.anthropic.com/v1
# LLM_PROVIDER_3_API_KEY=sk-ant-...
# LLM_PROVIDER_3_MODEL=claude-3-haiku-20240307

# =============================================================================
# SEARCH PROVIDERS - configure at least one
# =============================================================================

## Brave Search API (brave.com/search/api)
BRAVE_API_KEY=

## Tavily AI Search API (tavily.com)
TAVILY_API_KEY=

## Google Custom Search JSON API (programmable search engine)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
