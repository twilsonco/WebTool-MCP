# OpenAI-Compatible Endpoint (required for summarization)
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=                    # Optional - required if endpoint needs authentication
LLM_MODEL_NAME=llama3.2           # Model to use for summarization

# Search Providers - configure at least one
## Brave Search API (brave.com/search/api)
BRAVE_API_KEY=

## Tavily AI Search API (tavily.com)
TAVILY_API_KEY=

## Google Custom Search JSON API (programmable search engine)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
